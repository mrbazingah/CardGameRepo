  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "2\nWhen you play a 2, you can play any card you want next, regardless
    of the previous card's value.\n\n10\nPlaying a 10 clears and removes the entire
    pile from the game. You get another turn to play a card. \n\n4 of same value\nIf
    there are 4 cards of the same value on top of eachother on the pile then it has
    the same effect as placing a 10 and the player that placed the 4th card gets
    another turn."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
